# backend/.env.example
# Copy this file → rename to .env → fill your values

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=auth_app

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=24

# AES Encryption
AES_SECRET_KEY=your-32-character-aes-key-here
ENABLE_ENCRYPTION=False

# Email (Gmail App Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-digit-app-password
MAIL_FROM_NAME=First Fullstack App

# Reset Token
RESET_TOKEN_EXPIRY_MINUTES=15
FRONTEND_URL=http://localhost:4200

# Flask
FLASK_SECRET_KEY=your-flask-secret-here